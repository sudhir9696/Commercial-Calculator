# Copy this file to `.env` and fill in real values. `.env` is gitignored.
APIFY_TOKEN=
APIFY_DATASET_ID=

# Anthropic API key for the AI Analyst tab. Get one at
# https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# ScrapingBee API key — powers the "🪄 Auto-discover URLs" feature in the
# Deal Pipeline sidebar. Free tier ships 1,000 credits/month (no credit
# card required). Get yours at https://www.scrapingbee.com
SCRAPINGBEE_API_KEY=

# Opt-in flag for using the apify-client library instead of raw REST.
# REST is the default because apify-client v2 returns Pydantic models
# that previously broke our consumer code.
# APIFY_USE_CLIENT=0
